{
  "manifest_version": 3,
  "name": "GleamShot Capture",
  "description": "Capture a selected area and open it in the GleamShot editor.",
  "version": "0.1.0",
  "permissions": ["activeTab", "storage", "tabs", "downloads"],
  "icons": {
    "16": "assets/favicon.ico",
    "32": "assets/favicon.ico"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Capture with GleamShot",
    "default_icon": {
      "16": "assets/favicon.ico",
      "32": "assets/favicon.ico"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ]
}
